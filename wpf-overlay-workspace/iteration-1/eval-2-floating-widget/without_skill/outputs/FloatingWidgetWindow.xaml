<Window x:Class="ShortcutOverlay.FloatingWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shortcuts"
        Width="350"
        Height="500"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Grid>
        <!-- Main container with semi-transparent background -->
        <Border
            Background="#1A1A1A"
            CornerRadius="8"
            Opacity="0.95"
            Margin="8">
            <Border.Effect>
                <DropShadowEffect
                    Color="Black"
                    BlurRadius="10"
                    ShadowDepth="3"
                    Opacity="0.6"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with title and close button -->
                <Grid Grid.Row="0" Background="#0D47A1" Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Text="Shortcuts"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="12,8,8,8"
                        VerticalAlignment="Center"/>

                    <Button
                        Grid.Column="1"
                        Content="✕"
                        Width="32"
                        Height="32"
                        Margin="4"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="18"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#D32F2F"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#B71C1C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Shortcuts content area with scrolling -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <ItemsControl ItemsSource="{Binding ShortcutCategories}" Name="ShortcutsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Category header -->
                                    <TextBlock
                                        Grid.Row="0"
                                        Text="{Binding CategoryName}"
                                        Foreground="#64B5F6"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Margin="0,0,0,6"
                                        TextTransform="Uppercase"/>

                                    <!-- Shortcuts within category -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Shortcuts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Shortcut description -->
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        Text="{Binding Description}"
                                                        Foreground="#FFFFFF"
                                                        FontSize="11"
                                                        TextWrapping="Wrap"
                                                        Margin="8,0,8,0"/>

                                                    <!-- Key combination -->
                                                    <Border
                                                        Grid.Column="1"
                                                        Background="#424242"
                                                        BorderBrush="#616161"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="6,2,6,2"
                                                        Margin="8,0,0,0">
                                                        <TextBlock
                                                            Text="{Binding Keys}"
                                                            Foreground="#FFEB3B"
                                                            FontSize="10"
                                                            FontFamily="Courier New"
                                                            FontWeight="Bold"
                                                            VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
