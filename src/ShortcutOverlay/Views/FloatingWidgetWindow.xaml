<Window x:Class="ShortcutOverlay.Views.FloatingWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ShortcutOverlay.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="340"
        Height="480"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="12"
            Background="{DynamicResource OverlayBackground}"
            BorderBrush="{DynamicResource OverlayBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBackground}"
                    Padding="12,10"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentAppName}"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"
                               FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="&#x2630;"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Row 1: Search -->
            <Border Grid.Row="1" Padding="10,6">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         FontSize="12"
                         Foreground="{DynamicResource PrimaryText}"
                         Background="{DynamicResource SearchBackground}"
                         BorderBrush="{DynamicResource OverlayBorder}"
                         BorderThickness="1"
                         Tag="Search shortcuts..."
                         ToolTip="Type to filter shortcuts" />
            </Border>

            <!-- Row 2: Shared Shortcut List Control -->
            <controls:ShortcutListControl Grid.Row="2"
                                          Categories="{Binding FilteredCategories}" />

            <!-- Row 3: Footer -->
            <Border Grid.Row="3"
                    Background="{DynamicResource HeaderBackground}"
                    Padding="10,6"
                    CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Edit"
                            Style="{StaticResource FooterButton}"
                            Margin="0,0,4,0" />

                    <Button Grid.Column="1"
                            Content="Settings"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource FooterButton}"
                            Margin="4,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
