<Window x:Class="ShortcutOverlay.Views.FloatingWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ShortcutOverlay.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="340"
        Height="500"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Outer glass container with Apple-style rounded corners and glow -->
    <Border CornerRadius="14"
            Background="{DynamicResource OverlayBackground}"
            BorderBrush="{DynamicResource OverlayBorder}"
            BorderThickness="0.5"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.35" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: app name with subtle glass separator -->
            <Border Grid.Row="0"
                    Padding="14,12"
                    BorderBrush="{DynamicResource CategoryDivider}"
                    BorderThickness="0,0,0,0.5"
                    CornerRadius="14,14,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentAppName}"
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="SemiBold"
                               FontSize="15"
                               FontFamily="SF Pro Display, Segoe UI Semibold, sans-serif"
                               VerticalAlignment="Center" />

                    <!-- Hamburger menu icon -->
                    <TextBlock Grid.Column="1"
                               Text="&#x2630;"
                               Foreground="{DynamicResource TertiaryText}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Search: inset glass field -->
            <Border Grid.Row="1" Padding="12,8">
                <Border Background="{DynamicResource SearchBackground}"
                        BorderBrush="{DynamicResource SearchBorder}"
                        BorderThickness="0.5"
                        CornerRadius="8"
                        Padding="0">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,7"
                             FontSize="13"
                             FontFamily="SF Pro Text, Segoe UI, sans-serif"
                             Foreground="{DynamicResource SearchText}"
                             Background="Transparent"
                             BorderThickness="0"
                             Tag="Search shortcuts..."
                             ToolTip="Type to filter shortcuts" />
                </Border>
            </Border>

            <!-- Shortcut list: shared glass control -->
            <controls:ShortcutListControl Grid.Row="2"
                                          Categories="{Binding FilteredCategories}" />

            <!-- Footer: glass action bar -->
            <Border Grid.Row="3"
                    Padding="12,8"
                    BorderBrush="{DynamicResource CategoryDivider}"
                    BorderThickness="0,0.5,0,0"
                    CornerRadius="0,0,14,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Edit"
                            Style="{StaticResource FooterButton}"
                            Margin="0,0,4,0" />

                    <Button Grid.Column="1"
                            Content="Settings"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource FooterButton}"
                            Margin="4,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
