<Window x:Class="ShortcutOverlay.Views.ShortcutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Title="Hotglass — Shortcut Editor"
        Width="700"
        Height="550"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="14"
            Background="{DynamicResource OverlayBackground}"
            BorderBrush="{DynamicResource OverlayBorder}"
            BorderThickness="0.5"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3" Color="#000000" />
        </Border.Effect>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="4,0,4,10">
                <TextBlock Text="Shortcut Editor"
                           Foreground="{DynamicResource PrimaryText}"
                           FontWeight="SemiBold"
                           FontSize="16"
                           FontFamily="SF Pro Display, Segoe UI Semibold, sans-serif"
                           Effect="{StaticResource TextShadowLight}" />
                <TextBlock Text="✕"
                           HorizontalAlignment="Right"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="14" Cursor="Hand"
                           MouseLeftButtonDown="Close_Click"
                           ToolTip="Close" />
            </Grid>

            <!-- Main content: profiles list (left) + shortcuts (right) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left pane: Profile list -->
                <Border Grid.Column="0"
                        Background="{DynamicResource ShortcutRowBackground}"
                        CornerRadius="10"
                        Margin="0,0,6,0"
                        Padding="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="PROFILES" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource TertiaryText}"
                                   Typography.Capitals="AllSmallCaps"
                                   Margin="4,0,0,6" />

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource PrimaryText}"
                                 FontSize="12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Padding="4,3"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Right pane: Selected profile's categories and shortcuts -->
                <Border Grid.Column="1"
                        Background="{DynamicResource ShortcutRowBackground}"
                        CornerRadius="10"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Profile header -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding SelectedProfile.DisplayName, FallbackValue='Select a profile'}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,6" />

                        <!-- Category selector -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="CATEGORY" FontSize="10" FontWeight="Medium"
                                       Foreground="{DynamicResource TertiaryText}"
                                       Typography.Capitals="AllSmallCaps"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox ItemsSource="{Binding SelectedProfile.Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="Name"
                                      FontSize="12" MinWidth="140" />
                            <Button Content="+ Category" Style="{StaticResource FooterButton}"
                                    Padding="8,3" Margin="8,0,0,0" FontSize="11"
                                    Command="{Binding AddCategoryCommand}" />
                        </StackPanel>

                        <!-- Shortcuts list (editable) -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedCategory.Shortcuts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4"
                                                BorderBrush="{DynamicResource CategoryDivider}"
                                                BorderThickness="0,0,0,0.5"
                                                Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Keys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12" FontWeight="SemiBold"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Padding="4,2"
                                                         Tag="Key combo..." />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="11.5"
                                                         Foreground="{DynamicResource SecondaryText}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Padding="4,2"
                                                         Tag="Description..." />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Add shortcut button -->
                        <Button Grid.Row="3" Content="+ Add Shortcut"
                                Style="{StaticResource FooterButton}"
                                Padding="10,4" Margin="0,6,0,0"
                                FontSize="11" HorizontalAlignment="Left"
                                Command="{Binding AddShortcutCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Import section -->
            <Border Grid.Row="2" Margin="0,8,0,0" Padding="8,6"
                    Background="{DynamicResource ShortcutRowBackground}"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding ImportUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="11"
                             Padding="6,4"
                             Tag="Paste profile URL to import..."
                             VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Import URL"
                            Style="{StaticResource FooterButton}"
                            Padding="10,4" Margin="6,0,0,0" FontSize="11"
                            Command="{Binding ImportFromUrlCommand}" />
                    <Button Grid.Column="2" Content="Import File"
                            Style="{StaticResource FooterButton}"
                            Padding="10,4" Margin="4,0,0,0" FontSize="11"
                            Command="{Binding ImportFromFileCommand}" />
                </Grid>
            </Border>

            <!-- Footer: status + save -->
            <Grid Grid.Row="3" Margin="0,8,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <Button Content="Save Profile"
                        Style="{StaticResource FooterButton}"
                        Padding="14,5" HorizontalAlignment="Right"
                        FontSize="12"
                        Command="{Binding SaveProfileCommand}" />
            </Grid>
        </Grid>
    </Border>
</Window>
