<Window x:Class="ShortcutOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Width="380"
        Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="14"
            Background="{DynamicResource OverlayBackground}"
            BorderBrush="{DynamicResource OverlayBorder}"
            BorderThickness="0.5"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.35" Color="#000000" />
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Settings"
                           Foreground="{DynamicResource PrimaryText}"
                           FontWeight="SemiBold"
                           FontSize="16"
                           FontFamily="SF Pro Display, Segoe UI Semibold, sans-serif"
                           VerticalAlignment="Center"
                           Effect="{StaticResource TextShadowLight}" />
                <TextBlock Text="✕"
                           HorizontalAlignment="Right"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           MouseLeftButtonDown="Close_Click"
                           ToolTip="Close" />
            </Grid>

            <!-- Settings form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Theme -->
                    <TextBlock Text="THEME" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TertiaryText}"
                               Typography.Capitals="AllSmallCaps"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="ThemeCombo"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              FontSize="12"
                              Margin="0,0,0,14" />

                    <!-- Opacity -->
                    <TextBlock Text="OPACITY" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TertiaryText}"
                               Typography.Capitals="AllSmallCaps"
                               Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Value="{Binding Opacity, Mode=TwoWay}"
                                Minimum="0.3" Maximum="1.0"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding OpacityDisplay}"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </Grid>

                    <!-- Display Mode -->
                    <TextBlock Text="DISPLAY MODE" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TertiaryText}"
                               Typography.Capitals="AllSmallCaps"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="DisplayModeCombo"
                              SelectedValue="{Binding SelectedDisplayMode, Mode=TwoWay}"
                              SelectedValuePath="Tag"
                              FontSize="12"
                              Margin="0,0,0,14">
                        <ComboBoxItem Content="Floating Widget" Tag="floating" />
                        <ComboBoxItem Content="Side Panel" Tag="sidepanel" />
                        <ComboBoxItem Content="Tray Popup" Tag="tray" />
                    </ComboBox>

                    <!-- Global Hotkey -->
                    <TextBlock Text="GLOBAL HOTKEY" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TertiaryText}"
                               Typography.Capitals="AllSmallCaps"
                               Margin="0,0,0,4" />
                    <TextBox Text="{Binding GlobalHotkey, Mode=TwoWay}"
                             FontSize="12"
                             Padding="8,6"
                             Margin="0,0,0,14"
                             Tag="e.g. Ctrl+Shift+S"
                             IsReadOnly="True"
                             ToolTip="Hotkey rebinding coming soon" />

                    <!-- Lock Position (pin mode) -->
                    <CheckBox Content="Lock position"
                              IsChecked="{Binding AlwaysOnTop, Mode=TwoWay}"
                              Foreground="{DynamicResource PrimaryText}"
                              FontSize="12"
                              Margin="0,0,0,8"
                              ToolTip="When checked, the overlay cannot be dragged. Overlay always stays on top." />

                    <!-- Start with Windows -->
                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                              Foreground="{DynamicResource PrimaryText}"
                              FontSize="12"
                              Margin="0,0,0,14" />

                    <!-- About -->
                    <TextBlock Text="ABOUT" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TertiaryText}"
                               Typography.Capitals="AllSmallCaps"
                               Margin="0,0,0,4" />
                    <TextBlock Foreground="{DynamicResource SecondaryText}" FontSize="11" TextWrapping="Wrap">
                        <Run Text="Hotglass v1.0" FontWeight="SemiBold" />
                        <LineBreak />
                        <Run Text="An interactive keyboard shortcut overlay for Windows." />
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>

            <!-- Save / Cancel buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel" Style="{StaticResource FooterButton}"
                        Padding="16,6" Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="Save" Style="{StaticResource FooterButton}"
                        Padding="16,6"
                        Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
