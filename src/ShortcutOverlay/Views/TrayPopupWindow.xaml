<Window x:Class="ShortcutOverlay.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Width="320"
        Height="400"
        ResizeMode="NoResize">

    <Border CornerRadius="12"
            Background="{DynamicResource OverlayBackground}"
            BorderBrush="{DynamicResource OverlayBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBackground}"
                    Padding="12">
                <TextBlock Text="{Binding CurrentAppName}"
                           Foreground="{DynamicResource PrimaryText}"
                           FontWeight="Bold"
                           FontSize="14"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Row 1: Search -->
            <Border Grid.Row="1" Padding="12,8">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         FontSize="12"
                         Foreground="{DynamicResource PrimaryText}"
                         Background="{DynamicResource OverlayBackground}"
                         BorderBrush="{DynamicResource OverlayBorder}"
                         BorderThickness="1"
                         ToolTip="Search shortcuts..." />
            </Border>

            <!-- Row 2: Shortcuts List -->
            <ScrollViewer Grid.Row="2"
                          Margin="8"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding FilteredCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <!-- Category Name -->
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Opacity="0.7"
                                           Margin="0,0,0,6" />

                                <!-- Shortcuts in Category -->
                                <ItemsControl ItemsSource="{Binding Shortcuts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Key Badges -->
                                                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                                                    <ItemsControl ItemsSource="{Binding KeyParts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="3"
                                                                        Background="{DynamicResource KeyBadgeBackground}"
                                                                        BorderBrush="{DynamicResource KeyBadgeBorder}"
                                                                        BorderThickness="1"
                                                                        Padding="4,2"
                                                                        Margin="0,0,4,0">
                                                                    <TextBlock Text="{Binding}"
                                                                               Foreground="{DynamicResource KeyBadgeText}"
                                                                               FontSize="10"
                                                                               FontWeight="Bold"
                                                                               FontFamily="Consolas,Courier New" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </WrapPanel>

                                                <!-- Description -->
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Description}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           LineHeight="16" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Row 3: Footer -->
            <Border Grid.Row="3"
                    Background="{DynamicResource HeaderBackground}">
                <Border Padding="12" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Edit Shortcuts"
                                Margin="0,0,4,0"
                                Background="{DynamicResource KeyBadgeBackground}"
                                Foreground="{DynamicResource KeyBadgeText}"
                                BorderBrush="{DynamicResource KeyBadgeBorder}"
                                BorderThickness="1"
                                FontSize="11"
                                FontWeight="SemiBold">
                            <Button.Padding>
                                <Thickness>8,6,8,6</Thickness>
                            </Button.Padding>
                        </Button>

                        <Button Grid.Column="1"
                                Content="Settings"
                                Command="{Binding OpenSettingsCommand}"
                                Margin="4,0,0,0"
                                Background="{DynamicResource KeyBadgeBackground}"
                                Foreground="{DynamicResource KeyBadgeText}"
                                BorderBrush="{DynamicResource KeyBadgeBorder}"
                                BorderThickness="1"
                                FontSize="11"
                                FontWeight="SemiBold">
                            <Button.Padding>
                                <Thickness>8,6,8,6</Thickness>
                            </Button.Padding>
                        </Button>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
