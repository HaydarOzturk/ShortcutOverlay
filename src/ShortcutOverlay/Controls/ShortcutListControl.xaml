<UserControl x:Class="ShortcutOverlay.Controls.ShortcutListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ShortcutOverlay.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Categories, RelativeSource={RelativeSource AncestorType=local:ShortcutListControl}}"
                      Margin="10,4,10,10">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,8">
                        <!-- Category Header — Apple-style muted label -->
                        <TextBlock Text="{Binding Name}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="4,8,4,6"
                                   />

                        <!-- Shortcuts — glass card group -->
                        <Border Background="{DynamicResource ShortcutRowBackground}"
                                BorderBrush="{DynamicResource ShortcutRowBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="0">
                            <ItemsControl ItemsSource="{Binding Shortcuts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8"
                                                BorderBrush="{DynamicResource CategoryDivider}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="110"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Key badges (left) -->
                                                <local:KeyComboDisplay Grid.Column="0"
                                                                       Keys="{Binding Keys}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,12,0"/>

                                                <!-- Description (right) -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Description}"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
