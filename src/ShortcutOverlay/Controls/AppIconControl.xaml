<UserControl x:Class="ShortcutOverlay.Controls.AppIconControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="24" Height="24">

    <!-- Adaptive Hotglass icon: rounded-rect gradient background + white symbol overlay.
         The gradient colors bind to DynamicResource keys that ThemeAnimator transitions
         seamlessly, so the icon color shifts with the theme without any extra code. -->

    <Grid>
        <!-- Gradient background with rounded corners -->
        <Border CornerRadius="5" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="GradStop1" Color="{Binding Source={x:Static Application.Current}, Path=Resources[IconGradientStartColor]}" Offset="0" />
                    <GradientStop x:Name="GradStop2" Color="{Binding Source={x:Static Application.Current}, Path=Resources[IconGradientEndColor]}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <!-- Subtle inner glow for glass effect -->
            <Border CornerRadius="5" Opacity="0.15">
                <Border.Background>
                    <RadialGradientBrush Center="0.3,0.3" GradientOrigin="0.3,0.3" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Color="White" Offset="0" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Border>

        <!-- White symbol overlay — brackets + arrow fill most of the icon -->
        <Image Source="/Resources/Icons/symbol-48.png"
               Stretch="Uniform"
               Margin="3"
               RenderOptions.BitmapScalingMode="HighQuality" />
    </Grid>
</UserControl>
