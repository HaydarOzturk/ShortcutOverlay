<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Light Mode -->
    <!-- Frosted white glass with subtle depth -->

    <!-- Main overlay surface: bright frosted glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B0F5F5F7"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#20000000"/>

    <!-- Header: slightly tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#08000000"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F0000000"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#70000000"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#40000000"/>

    <!-- Key badges: frosted pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#18000000"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#10000000"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#D0000000"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#0C000000"/>
    <SolidColorBrush x:Key="SearchText" Color="#D0000000"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40000000"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#0A000000"/>

    <!-- Shortcut row containers -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#06000000"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#10000000"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#06000000"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10000000"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#08000000"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#15000000"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#80000000"/>

    <!-- Accent color (Apple blue) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FF007AFF"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#20007AFF"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#20000000"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
