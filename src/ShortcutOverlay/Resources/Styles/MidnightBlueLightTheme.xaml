<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Midnight Blue Light -->
    <!-- Soft frosted blue-white glass for bright backgrounds -->

    <!-- Main overlay surface: frosted blue-white glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#90DEEAF8"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#20406EBB"/>

    <!-- Header: subtle blue-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0A2050A0"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F00A1830"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#70183060"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#40284878"/>

    <!-- Key badges: frosted blue pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#183060A0"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#12406EBB"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#D00A1830"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#0C2050A0"/>
    <SolidColorBrush x:Key="SearchText" Color="#D00A1830"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#405070A0"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#0A406EBB"/>

    <!-- Shortcut row containers -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#06203860"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#10305888"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#06304878"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10406090"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#082050A0"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#15406EBB"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#80183060"/>

    <!-- Accent color (electric blue) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FF2563EB"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#202563EB"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#20406EBB"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
