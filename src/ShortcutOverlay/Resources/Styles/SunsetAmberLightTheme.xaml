<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Sunset Amber Light -->
    <!-- Soft frosted amber-white glass for bright backgrounds -->

    <!-- Main overlay surface: frosted amber-white glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#90F8F0E0"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#20C09038"/>

    <!-- Header: subtle amber-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0AA07828"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F02A1E0A"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#70503818"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#40785828"/>

    <!-- Key badges: frosted amber pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#18A07828"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#12C09038"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#D02A1E0A"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#0CA07828"/>
    <SolidColorBrush x:Key="SearchText" Color="#D02A1E0A"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40887040"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#0AC09038"/>

    <!-- Shortcut row containers -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#06604818"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#10886828"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#06705020"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10907040"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#08A07828"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#15C09038"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#80503818"/>

    <!-- Accent color (amber) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FFD97706"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#20D97706"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#20C09038"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
