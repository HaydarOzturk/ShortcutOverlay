<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Forest Green Light -->
    <!-- Soft frosted green-white glass for bright backgrounds -->

    <!-- Main overlay surface: frosted green-white glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#90E8F5E8"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#2058A850"/>

    <!-- Header: subtle green-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0A408838"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F01A2A10"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#70284820"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#40406838"/>

    <!-- Key badges: frosted green pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#18408838"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#1258A850"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#D01A2A10"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#0C408838"/>
    <SolidColorBrush x:Key="SearchText" Color="#D01A2A10"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40588850"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#0A58A850"/>

    <!-- Shortcut row containers -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#06284828"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#10387038"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#06305830"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10488848"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#08408838"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#1558A850"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#80284820"/>

    <!-- Accent color (emerald) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FF059669"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#20059669"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#2058A850"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
