<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Rose Gold -->
    <!-- Warm pinkish-gold glass, elegant on warm-toned or calibrated screens -->

    <!-- Main overlay surface: warm blush translucent glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B02A1A1A"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#18FF9EAA"/>

    <!-- Header: subtle rose-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0AE08890"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F0FFE4E8"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#80E0A8B0"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#50B07880"/>

    <!-- Key badges: frosted rose pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#20A05060"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#18C06878"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#E0FFD8E0"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#12804050"/>
    <SolidColorBrush x:Key="SearchText" Color="#E0FFE0E8"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40A07080"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#10C06878"/>

    <!-- Shortcut row containers: subtle glass cards -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#08603038"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#15884858"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#08704048"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10905060"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#10804050"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#20C06878"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#90E0A0B0"/>

    <!-- Accent color (rose pink) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FFF472B6"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#20F472B6"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#25C06878"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
