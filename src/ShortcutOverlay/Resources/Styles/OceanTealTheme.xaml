<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Ocean Teal -->
    <!-- Cool aqua-green glass, great on blue-light filtered or neutral screens -->

    <!-- Main overlay surface: deep teal translucent glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B00A2020"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#1850C8B8"/>

    <!-- Header: subtle teal-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0A30B0A0"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F0D8FFF8"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#8090D8C8"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#5060A098"/>

    <!-- Key badges: frosted teal pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#20208870"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#1830A890"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#E0D0FFF0"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#12207060"/>
    <SolidColorBrush x:Key="SearchText" Color="#E0D8FFF0"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#405898"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#1030A890"/>

    <!-- Shortcut row containers: subtle glass cards -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#08185040"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#15287860"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#08206050"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10308870"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#10207060"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#2030A890"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#9090D0C0"/>

    <!-- Accent color (teal cyan) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FF2DD4BF"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#202DD4BF"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#2530A890"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
