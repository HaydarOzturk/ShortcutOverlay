<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Forest Green -->
    <!-- Natural earth-green glass, easy on eyes for extended use -->

    <!-- Main overlay surface: deep forest translucent glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#80121A0A"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#1868A060"/>

    <!-- Header: subtle green-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0A50A048"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F0E8FFE8"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#80A0D098"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#5070A068"/>

    <!-- Key badges: frosted green pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#20408838"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#1858A850"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#E0E0FFD8"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#12387030"/>
    <SolidColorBrush x:Key="SearchText" Color="#E0E0FFE0"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40689860"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#1058A850"/>

    <!-- Shortcut row containers: subtle glass cards -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#08284828"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#15387038"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#08305830"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10488848"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#10387030"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#2058A850"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#90A0D098"/>

    <!-- Accent color (emerald green) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FF34D399"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#2034D399"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#2558A850"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
