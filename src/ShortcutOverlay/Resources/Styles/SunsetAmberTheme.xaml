<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Sunset Amber -->
    <!-- Warm amber-orange glass, comfortable on warm-lit or Night Light screens -->

    <!-- Main overlay surface: warm amber translucent glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B02A1E0E"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#18E0A050"/>

    <!-- Header: subtle amber-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0AD09040"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F0FFF0D8"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#80D8B880"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#50A88850"/>

    <!-- Key badges: frosted amber pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#20A07828"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#18C09038"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#E0FFF0D0"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#12806020"/>
    <SolidColorBrush x:Key="SearchText" Color="#E0FFF0D8"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40A08848"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#10C09038"/>

    <!-- Shortcut row containers: subtle glass cards -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#08604818"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#15886828"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#08705020"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10907040"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#10806020"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#20C09038"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#90D0B070"/>

    <!-- Accent color (amber orange) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FFFBBF24"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#20FBBF24"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#25C09038"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
