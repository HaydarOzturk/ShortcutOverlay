<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Apple Glass — Ocean Teal Light -->
    <!-- Soft frosted aqua-white glass for bright backgrounds -->

    <!-- Main overlay surface: frosted aqua-white glass -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#90E0F5F0"/>
    <SolidColorBrush x:Key="OverlayBorder" Color="#2030A890"/>

    <!-- Header: subtle teal-tinted layer -->
    <SolidColorBrush x:Key="HeaderBackground" Color="#0A208870"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="PrimaryText" Color="#F00A2820"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#70184838"/>
    <SolidColorBrush x:Key="TertiaryText" Color="#40286858"/>

    <!-- Key badges: frosted teal pill style -->
    <SolidColorBrush x:Key="KeyBadgeBackground" Color="#18208870"/>
    <SolidColorBrush x:Key="KeyBadgeBorder" Color="#1230A890"/>
    <SolidColorBrush x:Key="KeyBadgeText" Color="#D00A2820"/>

    <!-- Search field: inset glass -->
    <SolidColorBrush x:Key="SearchBackground" Color="#0C208870"/>
    <SolidColorBrush x:Key="SearchText" Color="#D00A2820"/>
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#40408878"/>
    <SolidColorBrush x:Key="SearchBorder" Color="#0A30A890"/>

    <!-- Shortcut row containers -->
    <SolidColorBrush x:Key="ShortcutRowBackground" Color="#06185040"/>
    <SolidColorBrush x:Key="ShortcutRowHover" Color="#10287860"/>
    <SolidColorBrush x:Key="ShortcutRowBorder" Color="#06206050"/>

    <!-- Category dividers -->
    <SolidColorBrush x:Key="CategoryDivider" Color="#10308870"/>

    <!-- Footer buttons -->
    <SolidColorBrush x:Key="FooterButtonBackground" Color="#08208870"/>
    <SolidColorBrush x:Key="FooterButtonHover" Color="#1530A890"/>
    <SolidColorBrush x:Key="FooterButtonText" Color="#80184838"/>

    <!-- Accent color (teal) -->
    <SolidColorBrush x:Key="AccentColor" Color="#FF0D9488"/>
    <SolidColorBrush x:Key="AccentColorSubtle" Color="#200D9488"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#2030A890"/>
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#00000000"/>

</ResourceDictionary>
